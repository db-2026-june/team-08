Table Inventory {
  inventory_id int [pk]
  ingredient_id int [ref: > Ingredients.ingredient_id]
  supplier_id int [ref: > Suppliers.supplier_id]
  location_id int [ref: > Locations.location_id]
  quantity int
  unit_cost decimal
  purchase_date date
  expiration_date date
}

Table Suppliers {
  supplier_id int [pk]
  supplier_name varchar
  country varchar
  city varchar
  street_address varchar
}

Table SupplierContacts {
  contact_id int [pk]
  supplier_id int [ref: > Suppliers.supplier_id]
  contact_name varchar
  phone_number varchar
  email varchar
}