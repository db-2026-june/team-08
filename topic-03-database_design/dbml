// Вставте ваш DBML-код нижче 👇

Table locations {
  location_id int PK
  location_name varchar(100) [not null]
  street varchar(150) [not null]
  city varchar(100) [not null]
  state_province varchar(100)
  postal_code varchar(20)
  country varchar(100) [not null]
  phone_number varchar(20)
}

Table staff {
  staff_id int PK
  location_id int [not null, ref: > Locations.location_id]
  staff_role varchar(100) [not null]
  first_name varchar(100) [not null]
  last_name varchar(100) [not null]
  phone_number varchar(20)
}

Table staff_shifts {
  staff_id int pk [ref: > Staff.staff_id]
  shift_id int pk [ref: > Shifts.shift_id]
}

Table shifts {
  shift_id int pk
  location_id int [not null, ref: > Locations.location_id]
  start_datetime datetime [not null]
  end_datetime datetime [not null]
}

Table Inventory {
  inventory_id int [pk]
  ingredient_id int [ref: > Ingredients.ingredient_id]
  supplier_id int [ref: > Suppliers.supplier_id]
  location_id int [ref: > Locations.location_id]
  quantity int
  unit_cost decimal
  purchase_date date
  expiration_date date
}

Table Suppliers {
  supplier_id int [pk]
  supplier_name varchar
  country varchar
  city varchar
  street_address varchar
}

Table SupplierContacts {
  contact_id int [pk]
  supplier_id int [ref: > Suppliers.supplier_id]
  contact_name varchar
  phone_number varchar
  email varchar
}

Table ingredients {
  ingredient_id int [pk]
  ingredient_name varchar(50)  [not null]
  unit varchar(20)  [not null]
}

Table menu_ingredients {
  ingredient_id int [pk, ref: > ingredients.ingredient_id]
  item_id int [pk, ref: > menu_items.item_id]
  quantity decimal(8,2)
}

Table menu_items {
  item_id int [pk]
  dish_name varchar(100)  [not null]
  price decimal(8,2)  [not null]
  preparation_time int  [not null]
  category_id int [not null, ref: > menu_categories.category_id]
}

Table menu_categories {
  category_id int [pk]
  category_name varchar(50)
}

Table location_ingredients{
  location_id int [pk, ref: > locations.location_id]
  ingredient_id int [pk, ref: > ingredients.ingredient_id]
  stock_quantity decimal(8,2)
}

Table Customers {
  customer_id int [pk]
  first_name varchar(100) [not null]
  last_name varchar(100) [not null]
  email varchar(255) [not null, unique]
  phone_number varchar(30)
  created_at timestamp [not null, default: `CURRENT_TIMESTAMP`]
}

Table Reviews {
  review_id int [pk]
  customer_id int [not null, ref: > Customers.customer_id]
  location_id int [not null, ref: > locations.location_id]
  rating smallint [not null]
  comment text
  review_date timestamp [not null, default: `CURRENT_TIMESTAMP`]

  checks {
    `rating BETWEEN 1 AND 5` [name: 'chk_reviews_rating']
  }
}

Table Orders{
  order_id int [PK]
  number int [not null]
  type varchar(50) [not null]
  status varchar(50) [not null]
  created_at time
  location_id int [not null, ref: > Locations.location_id ]
  customer_id int [not null, ref: > Customers.customer_id]
}

Table Reservations{
  reservation_id int [PK]
  reservation_time time
  reservation_date date
  status varchar(50)
  location_id int [not null, ref: > Locations.location_id]
  customer_id int [not null, ref: > Customers.customer_id]
}

Table OrderItem{
  order_id int [PK, ref: > Orders.order_id]
  item_id int [PK, ref: > MenuItems.item_id]
  quantity int [not null]
}

Table Tables{
  table_id int [PK]
  number int [not null]
  capacity int
  location_id int [not null, ref: > Locations.location_id]
}

Table TablesReservation{
  table_id int [PK, ref: > Tables.table_id]
  reservation_id int [PK, ref: > Reservations.reservation_id]
}

Table Customers{
  customer_id int [PK]



  
}
